<?xml version="1.0"?>
<robot name="mime_arm">
  <!-- Base Link -->
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder length="0.05" radius="0.1"/>
      </geometry>
      <material name="blue">
        <color rgba="0.2 0.2 1 1"/>
      </material>
    </visual>
  </link>

  <!-- Arm Link -->
  <link name="arm_link">
    <visual>
      <geometry>
        <box size="0.1 0.05 0.3"/>
      </geometry>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <material name="white">
        <color rgba="1 1 1 1"/>
      </material>
    </visual>
  </link>

  <!-- Thumb Link -->
  <link name="thumb_link">
    <visual>
      <geometry>
        <box size="0.02 0.02 0.1"/>
      </geometry>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <material name="red">
        <color rgba="1 0.2 0.2 1"/>
      </material>
    </visual>
  </link>

  <!-- Index Link -->
  <link name="index_link">
    <visual>
      <geometry>
        <box size="0.02 0.02 0.1"/>
      </geometry>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <material name="green">
        <color rgba="0.2 1 0.2 1"/>
      </material>
    </visual>
  </link>

  <!-- Fixed Joint attaching base to arm -->
  <joint name="base_to_arm" type="fixed">
    <parent link="base_link"/>
    <child link="arm_link"/>
    <origin xyz="0 0 0.025" rpy="0 0 0"/>
  </joint>

  <!-- Revolute Joint for Thumb -->
  <joint name="thumb_joint" type="revolute">
    <parent link="arm_link"/>
    <child link="thumb_link"/>
    <origin xyz="0.06 0 0.3" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="0" effort="10" velocity="3"/>
  </joint>

  <!-- Revolute Joint for Index Finger -->
  <joint name="index_joint" type="revolute">
    <parent link="arm_link"/>
    <child link="index_link"/>
    <origin xyz="-0.06 0 0.3" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="1.57" effort="10" velocity="3"/>
  </joint>
</robot>
